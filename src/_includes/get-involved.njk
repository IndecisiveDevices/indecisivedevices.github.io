<!-- Get Involved Section -->
<section id="get-involved" class="get-involved-section py-5">
  <div class="container">
    <h2 class="section-title text-center mb-5" data-aos="fade-up">
      Get Involved
    </h2>

    <div class="row">
      <!-- Join the Team -->
      <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="100">
        <div class="involvement-card">
          <div class="card-icon">👥</div>
          <h4>Join Our Team</h4>
          <p>
            Are you passionate about robotics and engineering? We're always
            looking for new team members! Whether you're interested in
            mechanical, electrical, or software engineering, there's a place
            for you on our team.
          </p>
        </div>
      </div>

      <!-- Become a Mentor -->
      <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="200">
        <div class="involvement-card">
          <div class="card-icon">🧑‍🏫</div>
          <h4>Become a Mentor</h4>
          <p>
            Share your expertise and inspire the next generation of
            engineers. Mentors play a crucial role in the success of our
            team. No experience necessary—just passion and a willingness to
            learn together!
          </p>
        </div>
      </div>

      <!-- Sponsor Us -->
      <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="300">
        <div class="involvement-card">
          <div class="card-icon">💼</div>
          <h4>Sponsor Us</h4>
          <p>
            Your sponsorship directly supports our team's growth and
            success. We offer tiered sponsorship levels with various
            visibility and engagement opportunities. Let's build something
            amazing together!
          </p>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="row mt-5">
      <div class="col-lg-8 offset-lg-2" data-aos="fade-up">
        <div class="contact-card">
          <h3 class="mb-4">Contact Us</h3>
          <form id="contact-form">
            <div class="mb-3">
              <label for="name" class="form-label">Name</label>
              <input
                type="text"
                class="form-control"
                id="contact-form-name"
                name="name"
                required
              />
            </div>
            <div class="mb-3">
              <label for="email" class="form-label">Email</label>
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                required
              />
            </div>
            <div class="mb-3">
              <label for="subject" class="form-label">Subject</label>
              <input
                type="text"
                class="form-control"
                id="subject"
                name="subject"
                required
              />
            </div>
            <div class="mb-3">
              <label for="message" class="form-label">Message</label>
              <textarea
                class="form-control"
                id="message"
                name="message"
                rows="5"
                required
              ></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-lg w-100">
              Send Message
            </button>
          </form>
          <p class="text-center small text-muted mt-3">
            We'll get back to you as soon as possible!
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
